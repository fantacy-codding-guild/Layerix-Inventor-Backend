generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url is configured in prisma.config.js
}

// --------------------------------------------------------
// TENANT & AUTHENTICATION
// --------------------------------------------------------

model Tenant {
  id            Int      @id @default(autoincrement())
  name          String
  subdomain     String   @unique
  contactEmail  String
  phone         String?
  address       String?
  city          String?
  state         String?
  country       String?
  logo          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users                User[]
  roles                Role[]
  settings             Setting[]
  brands               Brand[]
  serviceCategories    ServiceCategory[]
  products             Product[]
  vendors              Vendor[]
  customers            Customer[]
  projects             Project[]
  purchaseRequests     PurchaseRequest[]
  purchaseOrders       PurchaseOrder[]
  goodsReceived        GoodsReceived[]
  vendorInvoices       VendorInvoice[]
  amcs                 AMC[]
  breakFixes           BreakFix[]
  serviceTickets       ServiceTicket[]
  siteVisits           SiteVisit[]
  documents            Document[]
  activityLogs         ActivityLog[]
  stockMovements       StockMovement[]
}

model User {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  email         String
  passwordHash  String
  roleId        Int
  role          Role     @relation(fields: [roleId], references: [id])
  isActive      Boolean  @default(true)
  isVerified    Boolean  @default(false)
  otpCode       String?
  otpExpiry     DateTime?
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refreshTokens       RefreshToken[]
  activityLogs        ActivityLog[]
  createdPurchaseOrders PurchaseOrder[]  @relation("CreatedPO")
  managedProjects     Project[]          @relation("ProjectManager")
  serviceTickets      ServiceTicket[]    @relation("AssignedTickets")
  siteVisits          SiteVisit[]
  goodsReceived       GoodsReceived[]    @relation("ReceivedBy")
  stockMovements      StockMovement[]    @relation("StockMovementUser")
  purchaseRequests    PurchaseRequest[]  @relation("PurchaseRequestRequester")
  documents           Document[]         @relation("DocumentUploader")

  @@unique([tenantId, email])
}

model Role {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]

  @@unique([tenantId, name])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String?
  entityId    Int?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model Setting {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, key])
}

// --------------------------------------------------------
// MASTERS
// --------------------------------------------------------

model Brand {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]

  @@unique([tenantId, name])
}

model ServiceCategory {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  @@unique([tenantId, name])
}

model Product {
  id                Int       @id @default(autoincrement())
  tenantId          Int
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productCode       String
  name              String
  sku               String?
  brandId           Int?
  brand             Brand?    @relation(fields: [brandId], references: [id])
  modelNumber       String?
  serviceCategoryId Int?
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  unit              String    @default("Pcs")
  description       String?
  minStockLevel     Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  stock              Stock?
  vendorProducts     VendorProduct[]
  projectMaterialPlans ProjectMaterialPlan[]
  stockMovements     StockMovement[]
  reservations       StockReservation[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceivedItems GoodsReceivedItem[]

  @@unique([tenantId, productCode])
  @@index([tenantId, name])
  @@index([tenantId, sku])
}

model Stock {
  productId        Int      @id
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantityOnHand   Int      @default(0)
  reservedQuantity Int      @default(0)
  averageCost      Decimal? @db.Decimal(10,2)
  updatedAt        DateTime @updatedAt
}

model Vendor {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  companyName String?
  gstNumber   String?
  phone       String?
  alternatePhone  String? 
  email       String?
  address     String?
  city        String?
  state       String?
  country     String?
  website     String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendorProducts  VendorProduct[]
  purchaseOrders  PurchaseOrder[]
  goodsReceived   GoodsReceived[]
  vendorInvoices  VendorInvoice[]
  stockMovements  StockMovement[]   @relation("FromVendor")

  @@index([tenantId, name])
}

model VendorProduct {
  vendorId      Int
  productId     Int
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitPrice     Decimal? @db.Decimal(10,2)
  leadTimeDays  Int?
  isPreferred   Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@id([vendorId, productId])
}

model Customer {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  company   String?
  phone     String?
  email     String?
  gstNumber String?
  address   String?
  city      String?
  state     String?
  country   String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects       Project[]
  serviceTickets ServiceTicket[]
  amcContracts   AMC[]
  siteVisits     SiteVisit[]
  breakFixes     BreakFix[]
  stockMovements StockMovement[]   @relation("ToCustomer")

  @@index([tenantId, name])
}

// --------------------------------------------------------
// PROJECTS
// --------------------------------------------------------

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

model Project {
  id               Int           @id @default(autoincrement())
  tenantId         Int
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  customerId       Int
  customer         Customer      @relation(fields: [customerId], references: [id])
  location         String?
  projectValue     Decimal?      @db.Decimal(12,2)
  startDate        DateTime?
  endDate          DateTime?
  projectManagerId Int?
  projectManager   User?         @relation("ProjectManager", fields: [projectManagerId], references: [id])
  status           ProjectStatus @default(NOT_STARTED)
  overallProgress  Float         @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  milestones        ProjectMilestone[]
  materialPlans     ProjectMaterialPlan[]
  reservations      StockReservation[]
  siteVisits        SiteVisit[]
  serviceTickets    ServiceTicket[]
  amcs              AMC[]
  stockMovements    StockMovement[]   @relation("ToProject")
}

model ProjectMilestone {
  id          Int           @id @default(autoincrement())
  projectId   Int
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  progress    Float         @default(0)
  status      ProjectStatus @default(NOT_STARTED)
  orderIndex  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  materialPlans ProjectMaterialPlan[]   // <-- add this line
}

model ProjectMaterialPlan {
  id               Int      @id @default(autoincrement())
  projectId        Int
  productId        Int
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id])
  plannedQuantity  Int
  consumedQuantity Int      @default(0)

  // NEW: optional link to a specific milestone
  milestoneId      Int?
  milestone        ProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Remove the old unique constraint, now we can have multiple plans
  // for the same product in different milestones.
  // @@unique([projectId, productId])  <-- DELETE this line
}

// --------------------------------------------------------
// INVENTORY & STOCK MOVEMENTS
// --------------------------------------------------------

enum MovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
}

enum ReferenceType {
  PURCHASE_ORDER
  PROJECT
  MANUAL_ADJUSTMENT
  RETURN
}

model StockMovement {
  id            Int           @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product       @relation(fields: [productId], references: [id])

  type          MovementType
  quantity      Int
  unitPrice     Decimal?      @db.Decimal(10,2)

  fromVendorId  Int?
  fromVendor    Vendor?       @relation("FromVendor", fields: [fromVendorId], references: [id])
  toProjectId   Int?
  toProject     Project?      @relation("ToProject", fields: [toProjectId], references: [id])
  toCustomerId  Int?
  toCustomer    Customer?     @relation("ToCustomer", fields: [toCustomerId], references: [id])

  referenceType ReferenceType
  referenceId   Int?
  date          DateTime      @default(now())
  notes         String?
  createdBy     Int?
  user          User?         @relation("StockMovementUser", fields: [createdBy], references: [id])
  createdAt     DateTime      @default(now())

  @@index([tenantId, productId, date])
}

model StockReservation {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
  quantity  Int
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --------------------------------------------------------
// PROCUREMENT
// --------------------------------------------------------

model PurchaseRequest {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestNumber String
  requestedBy   Int?
  requester     User?    @relation("PurchaseRequestRequester", fields: [requestedBy], references: [id])
  dateRequired  DateTime?
  status        String   @default("DRAFT")
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         PurchaseRequestItem[]

  @@index([tenantId, requestNumber])
}

model PurchaseRequestItem {
  id                Int             @id @default(autoincrement())
  purchaseRequestId Int
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  productId         Int
  product           Product         @relation(fields: [productId], references: [id])
  quantity          Int
  estimatedPrice    Decimal?        @db.Decimal(10,2)
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

model PurchaseOrder {
  id                    Int                @id @default(autoincrement())
  tenantId              Int
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderNumber           String
  vendorId              Int
  vendor                Vendor             @relation(fields: [vendorId], references: [id])
  orderDate             DateTime           @default(now())
  expectedDeliveryDate  DateTime?
  status                PurchaseOrderStatus @default(DRAFT)
  totalAmount           Decimal?           @db.Decimal(12,2) @default(0)
  notes                 String?            @db.Text
  createdBy             Int?
  creator               User?              @relation("CreatedPO", fields: [createdBy], references: [id])
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  items         PurchaseOrderItem[]
  goodsReceived GoodsReceived[]
  invoices      InvoicePurchaseOrder[]

  @@unique([tenantId, orderNumber])
}

model PurchaseOrderItem {
  id              Int            @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Int
  unitPrice       Decimal?       @db.Decimal(10,2)
  totalPrice      Decimal?       @db.Decimal(10,2)
}

model GoodsReceived {
  id              Int       @id @default(autoincrement())
  tenantId        Int
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  grnNumber       String
  purchaseOrderId Int?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  vendorId        Int
  vendor          Vendor    @relation(fields: [vendorId], references: [id])
  receivedDate    DateTime  @default(now())
  receivedBy      Int?
  receiver        User?     @relation("ReceivedBy", fields: [receivedBy], references: [id])
  notes           String?
  createdAt       DateTime  @default(now())

  items           GoodsReceivedItem[]

  @@unique([tenantId, grnNumber])
}

model GoodsReceivedItem {
  id                  Int            @id @default(autoincrement())
  goodsReceivedId     Int
  goodsReceived       GoodsReceived  @relation(fields: [goodsReceivedId], references: [id], onDelete: Cascade)
  productId           Int
  product             Product        @relation(fields: [productId], references: [id])
  quantityReceived    Int
  purchaseOrderItemId Int?
}

model VendorInvoice {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceNumber String
  vendorId      Int
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  invoiceDate   DateTime @default(now())
  dueDate       DateTime?
  totalAmount   Decimal? @db.Decimal(12,2)
  status        String   @default("PENDING")
  paymentDate   DateTime?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders InvoicePurchaseOrder[]

  @@unique([tenantId, invoiceNumber])
}

model InvoicePurchaseOrder {
  invoiceId       Int
  invoice         VendorInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@id([invoiceId, purchaseOrderId])
}

// --------------------------------------------------------
// OPERATIONS
// --------------------------------------------------------

model AMC {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId      Int
  customer        Customer @relation(fields: [customerId], references: [id])
  projectId       Int?
  project         Project? @relation(fields: [projectId], references: [id])
  contractNumber  String
  startDate       DateTime
  endDate         DateTime
  serviceType     String
  frequency       String?
  amount          Decimal? @db.Decimal(12,2)
  status          String   @default("ACTIVE")
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, contractNumber])
}

model BreakFix {
  id           Int           @id @default(autoincrement())
  tenantId     Int
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId   Int
  customer     Customer      @relation(fields: [customerId], references: [id])
  ticketId     Int?
  ticket       ServiceTicket? @relation(fields: [ticketId], references: [id])
  description  String        @db.Text
  reportedDate DateTime      @default(now())
  resolvedDate DateTime?
  status       String        @default("OPEN")
  charges      Decimal?      @db.Decimal(10,2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ServiceTicket {
  id              Int           @id @default(autoincrement())
  tenantId        Int
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketNumber    String
  customerId      Int
  customer        Customer      @relation(fields: [customerId], references: [id])
  contactPerson   String?
  issueType       String?
  description     String        @db.Text
  priority        String        @default("MEDIUM")
  status          String        @default("OPEN")
  assignedTo      Int?
  assignee        User?         @relation("AssignedTickets", fields: [assignedTo], references: [id])
  projectId       Int?
  project         Project?      @relation(fields: [projectId], references: [id])
  siteVisitRequired Boolean     @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  siteVisits      SiteVisit[]
  breakFixes      BreakFix[]

  @@unique([tenantId, ticketNumber])
}

model SiteVisit {
  id            Int           @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketId      Int?
  ticket        ServiceTicket? @relation(fields: [ticketId], references: [id])
  projectId     Int?
  project       Project?      @relation(fields: [projectId], references: [id])
  customerId    Int
  customer      Customer      @relation(fields: [customerId], references: [id])
  scheduledDate DateTime
  actualDate    DateTime?
  engineerId    Int?
  engineer      User?         @relation(fields: [engineerId], references: [id])
  purpose       String?       @db.Text
  findings      String?       @db.Text
  status        String        @default("SCHEDULED")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// --------------------------------------------------------
// DOCUMENTS
// --------------------------------------------------------

enum EntityType {
  PRODUCT
  VENDOR
  CUSTOMER
  PROJECT
  TICKET
  PURCHASE_ORDER
  GOODS_RECEIVED
  VENDOR_INVOICE
  AMC
  SITE_VISIT
}

model Document {
  id          Int        @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  fileType    String?
  entityType  EntityType
  entityId    Int
  uploadedBy  Int?
  uploader    User?      @relation("DocumentUploader", fields: [uploadedBy], references: [id])
  createdAt   DateTime   @default(now())

  @@index([tenantId, entityType, entityId])
}