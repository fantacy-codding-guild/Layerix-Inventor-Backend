// --------------------------------------------------------
// VENDORS & CUSTOMERS
// --------------------------------------------------------
model Vendor {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  companyName String?
  gstNumber   String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendorProducts VendorProduct[]
  contacts       VendorContact[]
  stockMovements StockMovement[] @relation("FromVendor")

  inventoryItems  InventoryItem[]   @relation("VendorInventoryItems")

  @@index([tenantId, name])
}

model VendorContact {
  id          Int      @id @default(autoincrement())
  vendorId    Int
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  altPhone    String?
  email       String?
  designation String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vendorId])
}

model VendorProduct {
  vendorId     Int
  productId    Int
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitPrice    Decimal? @db.Decimal(10,2)
  leadTimeDays Int?
  isPreferred  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@id([vendorId, productId])
}

model Customer {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  company   String?
  phone     String?
  email     String?
  gstNumber String?
  address   String?
  city      String?
  state     String?
  country   String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects       Project[]
  stockMovements StockMovement[] @relation("ToCustomer")

  @@index([tenantId, name])
}

// --------------------------------------------------------
// STATE
// --------------------------------------------------------
model State {
  id             Int      @id @default(autoincrement())
  tenantId       Int
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  code           String
  region         String?
  projectManager String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projects Project[]
  @@unique([tenantId, name])
  @@unique([tenantId, code])
}

// --------------------------------------------------------
// PROJECTS
// --------------------------------------------------------
enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

model Project {
  id               Int           @id @default(autoincrement())
  tenantId         Int
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  code             String?       @unique
  customerId       Int?
  customer         Customer?     @relation(fields: [customerId], references: [id])
  stateId          Int?
  state            State?        @relation(fields: [stateId], references: [id])
  district         String?
  city             String?
  siteAddress      String?
  projectType      String?
  projectValue     Decimal?      @db.Decimal(12,2)
  startDate        DateTime?
  endDate          DateTime?
  completionPercent Float         @default(0)
  status           ProjectStatus @default(NOT_STARTED)
  overallProgress  Float         @default(0)
  projectManagerId Int?
  projectManager   User?         @relation("ProjectManager", fields: [projectManagerId], references: [id])
  location         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  projectStock   ProjectStock[]
  stockMovements StockMovement[] @relation("ToProject")
}

model ProjectStock {
  projectId        Int
  productId        Int
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantityOnSite   Int       @default(0)
  reservedQuantity Int       @default(0)
  updatedAt        DateTime  @updatedAt

  @@id([projectId, productId])
}

// --------------------------------------------------------
// STOCK MOVEMENTS
// --------------------------------------------------------
enum MovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
}

enum ReferenceType {
  PURCHASE_ORDER
  PROJECT
  MANUAL_ADJUSTMENT
  RETURN
}

model StockMovement {
  id            Int           @id @default(autoincrement())
  tenantId      Int
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product       @relation(fields: [productId], references: [id])
  type          MovementType
  quantity      Int
  unitPrice     Decimal?      @db.Decimal(10,2)
  fromVendorId  Int?
  fromVendor    Vendor?       @relation("FromVendor", fields: [fromVendorId], references: [id])
  toProjectId   Int?
  toProject     Project?      @relation("ToProject", fields: [toProjectId], references: [id])
  toCustomerId  Int?
  toCustomer    Customer?     @relation("ToCustomer", fields: [toCustomerId], references: [id])
  referenceType ReferenceType
  referenceId   Int?
  date          DateTime      @default(now())
  notes         String?
  createdBy     Int?
  user          User?         @relation("StockMovementUser", fields: [createdBy], references: [id])
  createdAt     DateTime      @default(now())

  @@index([tenantId, productId, date])
}

model InventoryItem {
  id               Int       @id @default(autoincrement())
  tenantId         Int
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId        Int
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  brand            String    // e.g. "commscope"
  unit             String    // e.g. "Pcs"
  vendorId         Int?
  vendor           Vendor?   @relation("VendorInventoryItems", fields: [vendorId], references: [id])
  quantityOnHand   Int       @default(0)
  reservedQuantity Int       @default(0)
  averageCost      Decimal?  @db.Decimal(10,2)
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  @@unique([tenantId, productId, brand, unit, vendorId])
  @@index([tenantId, productId])
}