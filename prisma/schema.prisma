generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------
// TENANT
// --------------------------------------------------------
model Tenant {
  id            Int      @id @default(autoincrement())
  name          String
  subdomain     String   @unique
  contactEmail  String
  phone         String?
  address       String?
  city          String?
  state         String?
  country       String?
  logo          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users             User[]
  roles             Role[]
  settings          Setting[]
  brands            Brand[]
  serviceCategories ServiceCategory[]
  products          Product[]
  vendors           Vendor[]
  customers         Customer[]
  projects          Project[]
  states            State[]
  activityLogs      ActivityLog[]
  stockMovements    StockMovement[]

  inventoryItems     InventoryItem[]

}



// --------------------------------------------------------
// USER
// --------------------------------------------------------
model User {
  id                 Int      @id @default(autoincrement())
  tenantId           Int
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  email              String
  passwordHash       String
  roleId             Int
  role               Role     @relation(fields: [roleId], references: [id])
  isActive           Boolean  @default(true)
  isVerified         Boolean  @default(false)
  otpCode            String?
  otpExpiry          DateTime?
  lastLogin          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  forcePasswordReset Boolean  @default(false)

  refreshTokens   RefreshToken[]
  activityLogs    ActivityLog[]
  managedProjects Project[]        @relation("ProjectManager")
  stockMovements  StockMovement[]  @relation("StockMovementUser")

  @@unique([tenantId, email])
}

// --------------------------------------------------------
// ROLES, TOKENS, LOGS, SETTINGS
// --------------------------------------------------------
model Role {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  @@unique([tenantId, name])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String?
  entityId    Int?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model Setting {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
  @@unique([tenantId, key])
}

// --------------------------------------------------------
// MASTERS
// --------------------------------------------------------
model Brand {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
}

model ServiceCategory {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
  @@unique([tenantId, name])
}

model Product {
  id                Int       @id @default(autoincrement())
  tenantId          Int
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productCode       String
  name              String
  modelNumber       String?
  serviceCategoryId Int?
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  unit              String    @default("Pcs")
  description       String?
  minStockLevel     Int       @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

 
  vendorProducts VendorProduct[]
  projectStocks  ProjectStock[]
  stockMovements StockMovement[]

  @@unique([tenantId, productCode])
  @@index([tenantId, name])

  inventoryItems     InventoryItem[]
}

